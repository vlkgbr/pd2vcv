#N canvas 827 239 734 565 12;
#X obj 145 44 r switch_onoff @hv_param 0 1 0;
#X obj 387 44 r base_time @hv_param 1 10000 1000;
#X obj 145 260 line~;
#X msg 145 217 1 \, 0 1;
#X obj 145 177 metro 2000;
#X obj 145 302 *~ 10;
#X obj 145 359 dac~ 1;
#X obj -68 359 s onoff_dac1 @hv_param;
#X text 139 -49 the switch_ prefix creates a physical toggle switch (CKSS). It latches \, sends 1 when flipped UP \, and 0 when flipped DOWN. Perfect for turning a [metro] on and off., f 33;
#X text 387 -41 The base_ prefix creates a large primary knob. We use it here to dynamically change the millisecond delay time of the metro., f 33;
#X text 209 222 [metro] outputs bangs \, but VCV Rack requires audio signals. This block converts the bang into a 1ms \, 10V audio pulse (the standard for VCV Rack triggers/clocks)., f 27;
#X text -68 216 Because this shares the core name 'onoff' with the switch \, the dac~ 1 output jack will be drawn at the bottom of the same column. Actual CV goes through [dac~ 1]. [s onoff_dac1] is just a dummy for the UI layout., f 26;
#X connect 0 0 4 0;
#X connect 1 0 4 1;
#X connect 2 0 5 0;
#X connect 3 0 2 0;
#X connect 4 0 3 0;
#X connect 5 0 6 0;
