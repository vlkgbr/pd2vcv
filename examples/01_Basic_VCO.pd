#N canvas 827 239 734 565 12;
#X obj 191 -62 adc~ 1 2;
#X obj 270 168 r base_pitch_adc1 @hv_param 0 127 64;
#X obj 270 421 mtof~;
#X obj 270 213 sig~;
#X text 310 212 convert knob value to signal;
#X text 330 252 low-pass filter to smooth out the values;
#X obj 270 253 lop~ 20;
#X text 337 407 convert midi values (0-127) to frequency;
#X obj 191 213 *~ 12;
#X obj 270 309 +~;
#X text 10 213 scale 1V/Oct to 12 semitones;
#X obj 596 -181 r attenv_fm_adc2 @hv_param -1 1 0, f 31;
#X obj 596 -134 sig~;
#X text 636 -135 convert knob value to signal;
#X text 656 -95 low-pass filter to smooth out the values;
#X obj 596 -94 lop~ 20;
#X obj 596 3 *~;
#X obj 590 342 *~ 12;
#X text 437 -49 the FM CV input;
#X text 650 341 scale the FM depth to 1V/Oct so it matches standard VCV pitch depth;
#X obj 270 359 +~;
#X text 353 338 add the FM modulation to the main pitch;
#X obj 270 465 osc~;
#X obj 270 546 dac~ 1;
#X text 337 545 mono output;
#X text 191 -95 adc 1 -> v/oct input \, adc 2 FM CV input;
#X text 270 79 The 'base_' prefix generates a large main knob. The '_adc1' suffix tells the UI generator to draw the adc~ 1 input jack directly underneath this knob., f 34;
#X text 596 -269 The 'attenv_' prefix generates a small \, bipolar attenuverter knob. The '-1 1 0' sets its range. The '_adc2' suffix draws the adc~ 2 input jack directly below it., f 32;
#X text 636 2 multiply the incoming FM CV by the knob's value (-1 to 1);
#X text 250 -356 How Columns Work: The text in the middle of your parameter name is the "core name". For example \, base_pitch_adc1 creates a column named PITCH. attenv_fm_adc2 creates a column named FM. Any parameters sharing the same core name will stack vertically in that column;
#X text 191 -207 We use [adc~] to receive actual audio/CV signals. The _adcN suffix in the parameter name only tells the layout script to draw that physical jack in the same vertical column as the knob., f 35;
#X obj 270 498 *~ 5;
#X text 323 497 scales Pd's ±1.0 to VCV's ±5.0V audio standard;
